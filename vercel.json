{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://3-esquinas-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!assets/|images/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
